{
  "name": "nextchange-hub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "server:dev": "node --watch server/index.js"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^3.1.0",
    "@xenova/transformers": "^2.17.2",
    "autoprefixer": "^10.4.27",
    "axios": "^1.14.0",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "ecpair": "^3.0.1",
    "ethers": "^6.16.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^1.7.0",
    "node-llama-cpp": "^3.18.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.3",
    "react-router": "^7.14.0",
    "sql.js": "^1.12.0",
    "tailwindcss": "^4.2.2",
    "tiny-secp256k1": "^2.2.4",
    "uuid": "^11.1.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1",
    "vite-plugin-node-polyfills": "^0.26.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.nextchange.hub",
    "productName": "NextChange Hub",
    "icon": "public/logo_circular.png",
    "files": [
      "dist/**/*",
      "electron-main.js",
      "electron-preload.js",
      "server/**/*",
      "bin/**/*",
      "!server/node_modules",
      "!server/.env"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Catipal",
        "repo": "nextchange",
        "releaseType": "draft"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "identity": null
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
